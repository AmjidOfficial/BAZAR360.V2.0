{
  "entities": {
    "user": {
      "title": "User Account",
      "description": "Core account credentials and registration status for Firebase Auth sync.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique Firebase Authentication UID." },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "phoneVerified": { "type": "boolean" },
        "role": { "type": "string", "enum": ["Visitor", "Individual User", "Showroom Owner", "Admin"] },
        "status": { "type": "string", "enum": ["Active", "Pending", "Suspended"] },
        "acceptedTerms": { "type": "boolean" },
        "preferredLanguage": { "type": "string", "enum": ["en", "ur"] },
        "preferredTheme": { "type": "string", "enum": ["light", "dark"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "status", "createdAt"]
    },
    "profile": {
      "title": "User Profile",
      "description": "Complete editable profile storing comprehensive human-readable personal information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "profilePhoto": { "type": "string" },
        "gender": { "type": "string" },
        "dob": { "type": "string" },
        "country": { "type": "string" },
        "province": { "type": "string" },
        "city": { "type": "string" },
        "address": { "type": "string" },
        "bio": { "type": "string" },
        "notificationSettings": {
          "type": "object",
          "properties": {
            "emailAlerts": { "type": "boolean" },
            "smsAlerts": { "type": "boolean" },
            "whatsappAlerts": { "type": "boolean" }
          }
        },
        "privacySettings": {
          "type": "object",
          "properties": {
            "showPhonePublicly": { "type": "boolean" },
            "showEmailPublicly": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "createdAt"]
    },
    "showroom": {
      "title": "Showroom Business Profile",
      "description": "Detailed showroom dealership metadata, branding, and registration details.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique showroom ID or slug." },
        "name": { "type": "string" },
        "ownerUid": { "type": "string" },
        "mobile": { "type": "string" },
        "whatsapp": { "type": "string" },
        "email": { "type": "string" },
        "website": { "type": "string" },
        "logo": { "type": "string" },
        "coverImage": { "type": "string" },
        "gallery": { "type": "array", "items": { "type": "string" } },
        "videos": { "type": "array", "items": { "type": "string" } },
        "address": { "type": "string" },
        "googleMap": { "type": "string" },
        "ntn": { "type": "string" },
        "registrationNumber": { "type": "string" },
        "businessDocuments": { "type": "array", "items": { "type": "string" } },
        "verified": { "type": "boolean" },
        "activeTheme": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerUid", "createdAt"]
    },
    "showroomStaff": {
      "title": "Showroom Staff Assignment",
      "description": "Links users as team members to parent showrooms with granular delegation roles.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "showroomId": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "role": { "type": "string", "enum": ["CEO", "Manager", "Sales Representative"] },
        "phone": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "showroomId", "userId", "role", "active"]
    },
    "vehicle": {
      "title": "Vehicle Post",
      "description": "Consolidated listing details, pricing, and specs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "brand": { "type": "string" },
        "make": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "integer" },
        "priceRaw": { "type": "integer" },
        "mileageRaw": { "type": "integer" },
        "fuelType": { "type": "string" },
        "transmission": { "type": "string" },
        "description": { "type": "string" },
        "approved": { "type": "boolean" },
        "isSold": { "type": "boolean" },
        "isReserved": { "type": "boolean" },
        "isPremium": { "type": "boolean" },
        "images": { "type": "array", "items": { "type": "string" } },
        "createdBy": { "type": "string" },
        "dealerId": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Pending", "Approved", "Sold", "Rejected"] },
        "activeFlag": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "priceRaw", "createdBy", "status", "activeFlag", "createdAt"]
    },
    "vehicleImage": {
      "title": "Vehicle Image Meta",
      "description": "Metadata for uploaded listing media assets.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicleId": { "type": "string" },
        "url": { "type": "string" },
        "size": { "type": "integer" },
        "mimeType": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "vehicleId", "url", "uploadedBy"]
    },
    "vehicleVideo": {
      "title": "Vehicle Video Meta",
      "description": "Metadata for uploaded walkaround videos.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicleId": { "type": "string" },
        "url": { "type": "string" },
        "size": { "type": "integer" },
        "duration": { "type": "integer" },
        "uploadedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "vehicleId", "url", "uploadedBy"]
    },
    "favorite": {
      "title": "User Favorite Mapping",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "vehicleId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "vehicleId"]
    },
    "message": {
      "title": "Chat Message Document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["id", "chatId", "senderId", "text", "timestamp"]
    },
    "chat": {
      "title": "Chat Thread Record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participantIds": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "lastMessageSenderId": { "type": "string" }
      },
      "required": ["id", "participantIds"]
    },
    "notification": {
      "title": "In-App Notification Banner",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "read": { "type": "boolean" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "body", "read"]
    },
    "searchHistory": {
      "title": "Saved Search Keywords",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "queryText": { "type": "string" },
        "filters": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "queryText"]
    },
    "recentView": {
      "title": "Recently Viewed Carousel Logs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "vehicleId": { "type": "string" },
        "viewedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "vehicleId"]
    },
    "review": {
      "title": "Showroom Review Log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "targetId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "targetId", "authorName", "rating", "comment"]
    },
    "rating": {
      "title": "Dealership Scorecard Rollup",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "targetId": { "type": "string" },
        "averageRating": { "type": "number" },
        "totalRatings": { "type": "integer" }
      },
      "required": ["id", "targetId", "averageRating", "totalRatings"]
    },
    "lead": {
      "title": "Customer CRM Lead Tracker",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "userName": { "type": "string" },
        "userPhone": { "type": "string" },
        "userEmail": { "type": "string" },
        "city": { "type": "string" },
        "details": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "userName", "userPhone", "createdAt"]
    },
    "visitor": {
      "title": "Visitor clickstream",
      "type": "object",
      "properties": {
        "visitorId": { "type": "string" },
        "firstSeen": { "type": "string" },
        "lastSeen": { "type": "string" },
        "frequencyCategory": { "type": "string" },
        "sessionCount": { "type": "integer" },
        "totalViews": { "type": "integer" }
      },
      "required": ["visitorId", "firstSeen"]
    },
    "supportTicket": {
      "title": "Support Desk Ticket",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Resolved", "Closed"] },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userName", "title", "status"]
    },
    "payment": {
      "title": "Payment Order Log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "integer" },
        "currency": { "type": "string" },
        "status": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "paymentType": { "type": "string" },
        "transactionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "amount", "status"]
    },
    "subscription": {
      "title": "Showroom Premium Package",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "status": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "autoRenew": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "planId", "status"]
    },
    "advertisement": {
      "title": "Sponsor Banner Slot",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "imageUrl": { "type": "string" },
        "targetUrl": { "type": "string" },
        "position": { "type": "string" },
        "status": { "type": "string" },
        "views": { "type": "integer" },
        "clicks": { "type": "integer" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "imageUrl", "position", "status"]
    },
    "analytics": {
      "title": "Business Intelligence Telemetry Log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "eventType": { "type": "string" },
        "eventName": { "type": "string" },
        "userId": { "type": "string" },
        "sessionId": { "type": "string" },
        "properties": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "eventType", "eventName", "timestamp"]
    },
    "settings": {
      "title": "System Parameters",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "key": { "type": "string" },
        "value": { "type": "string" },
        "description": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "key", "value"]
    },
    "auditLog": {
      "title": "Security Trail Log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userRole": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userName", "action", "timestamp"]
    },
    "seo": {
      "title": "SEO Page Descriptor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "pagePath": { "type": "string" },
        "metaTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "canonicalUrl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "pagePath", "metaTitle"]
    },
    "systemLog": {
      "title": "Application Critical System Log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "severity": { "type": "string" },
        "message": { "type": "string" },
        "stackTrace": { "type": "string" },
        "component": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "severity", "message", "timestamp"]
    }
  },
  "firestore": {
    "system/seeded": {
      "schema": { "type": "object" },
      "description": "Global database seeding sentinel."
    },
    "users/{userId}": {
      "schema": "user",
      "description": "Enterprise secure credentials, role mapping, and status indicators."
    },
    "profiles/{profileId}": {
      "schema": "profile",
      "description": "Rich, split-collection user personal information (PII-isolated)."
    },
    "showrooms/{showroomId}": {
      "schema": "showroom",
      "description": "High-fidelity showroom brands and configurations."
    },
    "showroomStaff/{staffId}": {
      "schema": "showroomStaff",
      "description": "Links users to dealers for backend privilege elevation."
    },
    "vehicles/{vehicleId}": {
      "schema": "vehicle",
      "description": "Consolidated luxury automotive inventory postings."
    },
    "vehicleImages/{imageId}": {
      "schema": "vehicleImage",
      "description": "Photo asset storage schemas."
    },
    "vehicleVideos/{videoId}": {
      "schema": "vehicleVideo",
      "description": "Video walkthrough metadata tracking."
    },
    "favorites/{favoriteId}": {
      "schema": "favorite",
      "description": "User saved/bookmarked listing linkages."
    },
    "messages/{messageId}": {
      "schema": "message",
      "description": "Granular chat exchange records."
    },
    "chats/{chatId}": {
      "schema": "chat",
      "description": "Ongoing user conversation metadata records."
    },
    "notifications/{notificationId}": {
      "schema": "notification",
      "description": "System-generated transactional alerts."
    },
    "searchHistory/{searchId}": {
      "schema": "searchHistory",
      "description": "Visitor organic search filters snapshot tracker."
    },
    "recentViews/{viewId}": {
      "schema": "recentView",
      "description": "Recents carousel logs."
    },
    "reviews/{reviewId}": {
      "schema": "review",
      "description": "Dealership user ratings and textual reviews."
    },
    "ratings/{ratingId}": {
      "schema": "rating",
      "description": "Showroom ratings statistics summaries."
    },
    "leads/{leadId}": {
      "schema": "lead",
      "description": "Captured inquiries for dealership analytics."
    },
    "visitors/{visitorId}": {
      "schema": "visitor",
      "description": "Session clickstream telemetry."
    },
    "supportTickets/{ticketId}": {
      "schema": "supportTicket",
      "description": "Customer support logs."
    },
    "payments/{paymentId}": {
      "schema": "payment",
      "description": "Ad postings transaction ledger."
    },
    "subscriptions/{subscriptionId}": {
      "schema": "subscription",
      "description": "Dealer premium tier registrations."
    },
    "advertisements/{adId}": {
      "schema": "advertisement",
      "description": "Targeted marketing campaigns."
    },
    "analytics/{analyticsId}": {
      "schema": "analytics",
      "description": "Aggregated BI tracker records."
    },
    "settings/{settingId}": {
      "schema": "settings",
      "description": "Core dynamic app constants."
    },
    "auditLogs/{logId}": {
      "schema": "auditLog",
      "description": "Transactional user activity security ledger."
    },
    "seo/{seoId}": {
      "schema": "seo",
      "description": "Custom programmatic metadata injections."
    },
    "systemLogs/{logId}": {
      "schema": "systemLog",
      "description": "Critical client/server runtime diagnostic reports."
    }
  }
}
