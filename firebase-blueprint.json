{
  "entities": {
    "user": {
      "title": "User Profile",
      "description": "Standard profiles for admins, showroom owners, sales reps, and buyers within Bazar360.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique Firebase Authentication UID." },
        "email": { "type": "string", "format": "email", "description": "Email address of the registered profile." },
        "displayName": { "type": "string", "description": "Full name of the user." },
        "phoneNumber": { "type": "string", "description": "Verified or registered phone number of the user." },
        "phoneVerified": { "type": "boolean", "description": "Indicates if the phone number was verified via OTP." },
        "role": { "type": "string", "enum": ["Admin", "Showroom Owner", "Sales Rep", "Private Seller", "Buyer", "Dealer"] },
        "status": { "type": "string", "enum": ["Active", "Pending Approval", "Suspended"] },
        "showroomId": { "type": "string", "description": "Optional reference to the owned showroom." },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "displayName", "role", "status", "createdAt", "lastLogin"]
    },
    "visitor": {
      "title": "Visitor Session Log",
      "description": "Visitor session telemetry, analyzing frequency (1st Time, 2nd Time, Regular) and full search/view clickstream.",
      "type": "object",
      "properties": {
        "visitorId": { "type": "string", "description": "Client-generated persistent cookie uuid." },
        "firstSeen": { "type": "string", "format": "date-time" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "frequencyCategory": { "type": "string", "enum": ["1st Time", "2nd Time", "3rd Time", "Regular"] },
        "sessionCount": { "type": "integer" },
        "totalViews": { "type": "integer" },
        "searchHistory": { "type": "array", "items": { "type": "string" } },
        "viewHistory": { "type": "array", "items": { "type": "string" } },
        "clicksToCall": { "type": "integer" },
        "clicksToWhatsApp": { "type": "integer" },
        "deviceMetrics": {
          "type": "object",
          "properties": {
            "viewportWidth": { "type": "integer" },
            "viewportHeight": { "type": "integer" },
            "userAgent": { "type": "string" }
          }
        }
      },
      "required": ["visitorId", "firstSeen", "lastSeen", "frequencyCategory", "sessionCount"]
    },
    "showroom": {
      "title": "Showroom Dealership Profile",
      "description": "Multi-tenant showroom brand containing customizable metadata, layouts, themes, and physical addresses.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique URL slug or identifier of the showroom." },
        "name": { "type": "string", "description": "Dealership brand name." },
        "avatarUrl": { "type": "string" },
        "subtitle": { "type": "string" },
        "location": { "type": "string" },
        "rating": { "type": "number" },
        "vehiclesCount": { "type": "integer" },
        "followersCount": { "type": "string" },
        "coverImage": { "type": "string" },
        "description": { "type": "string" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "flagshipVerified": { "type": "boolean" },
        "themeSettings": {
          "type": "object",
          "properties": {
            "primaryColor": { "type": "string" },
            "secondaryColor": { "type": "string" },
            "fontFamily": { "type": "string" },
            "bgStyle": { "type": "string", "enum": ["dark", "light", "emerald", "gold"] }
          }
        },
        "socials": {
          "type": "object",
          "properties": {
            "facebook": { "type": "string" },
            "instagram": { "type": "string" },
            "tiktok": { "type": "string" },
            "youtube": { "type": "string" },
            "website": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "location", "phone", "whatsapp", "createdAt"]
    },
    "vehicle": {
      "title": "Vehicle Listing",
      "description": "Individual automotive vehicle post, with status tracking, specifications, approvals, and pricing logs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "dealerId": { "type": "string", "description": "Belonging showroom or 'private' identifier." },
        "title": { "type": "string" },
        "brand": { "type": "string" },
        "modelYear": { "type": "string" },
        "priceRaw": { "type": "integer", "description": "Price in PKR." },
        "priceFormatted": { "type": "string" },
        "mileage": { "type": "string" },
        "mileageRaw": { "type": "integer" },
        "fuelType": { "type": "string", "enum": ["Petrol", "Diesel", "Hybrid", "Electric"] },
        "transmission": { "type": "string", "enum": ["Automatic", "Manual"] },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "exteriorColor": { "type": "string" },
        "conditionScore": { "type": "number" },
        "description": { "type": "string" },
        "approved": { "type": "boolean", "description": "Admin approval workflow state indicator." },
        "isSold": { "type": "boolean" },
        "isReserved": { "type": "boolean" },
        "isPremium": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "dealerId", "title", "brand", "priceRaw", "approved", "createdAt"]
    },
    "lead": {
      "title": "Lead Inquiry Record",
      "description": "High-intent client actions tracking CTR, call requests, WhatsApp routes, and Concierge inquiries.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["Showroom Lead", "Request Callback", "WhatsApp Connect", "Call Connect", "Concierge Inquiry"] },
        "title": { "type": "string" },
        "userName": { "type": "string" },
        "userPhone": { "type": "string" },
        "userEmail": { "type": "string" },
        "city": { "type": "string" },
        "details": { "type": "string" },
        "metadata": {
          "type": "object",
          "properties": {
            "sourceShowroomId": { "type": "string" },
            "viewedInventoryId": { "type": "string" },
            "intentCategory": { "type": "string" },
            "deviceContext": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "userName", "userPhone", "createdAt"]
    },
    "suggestion": {
      "title": "Marketplace Suggestion Feed",
      "description": "General visitor submissions regarding marketplace expansions and categories.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "suggestion_text": { "type": "string" },
        "submitted_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "suggestion_text", "submitted_at"]
    },
    "ad_workflow_log": {
      "title": "Ad State Machine Log",
      "description": "History of ad postings, state progression, and approvals.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "listingId": { "type": "string" },
        "action": { "type": "string", "enum": ["Create Draft", "Submit For Review", "Approve", "Reject", "Archive", "Toggle Premium", "Toggle Sold", "Toggle Reserved"] },
        "performedBy": { "type": "string", "description": "UID or 'visitor'." },
        "previousState": { "type": "string" },
        "newState": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["id", "listingId", "action", "performedBy", "timestamp"]
    }
  },
  "firestore": {
    "system/seeded": {
      "schema": { "type": "object" },
      "description": "Global database seeding sentinel."
    },
    "users/{userId}": {
      "schema": "user",
      "description": "Collection of user registration profiles."
    },
    "visitors/{visitorId}": {
      "schema": "visitor",
      "description": "Clickstream and session frequency analyzer logs."
    },
    "dealers/{dealerId}": {
      "schema": "showroom",
      "description": "Multi-tenant physical & digital showroom registry."
    },
    "listings/{listingId}": {
      "schema": "vehicle",
      "description": "Consolidated luxury marketplace inventory allocation listings."
    },
    "leads/{leadId}": {
      "schema": "lead",
      "description": "CRM dashboard lead capturing records."
    },
    "suggestions/{suggestionId}": {
      "schema": "suggestion",
      "description": "Crowdsourced category expansion requests."
    },
    "logs/{logId}": {
      "schema": "ad_workflow_log",
      "description": "Audit trails for listings status machine transitions."
    }
  }
}
