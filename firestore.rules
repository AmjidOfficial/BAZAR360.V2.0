rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // REUSABLE HELPER FUNCTIONS & RBAC DECORATORS
    // ==========================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role Fetch Checks
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('Admin');
    }

    function isShowroomOwner() {
      return hasRole('Showroom Owner');
    }

    function isIndividualUser() {
      return hasRole('Individual User') || hasRole('Private Seller') || hasRole('Buyer');
    }

    // Incoming payload validation convenience
    function incoming() {
      return request.resource.data;
    }

    // ==========================================
    // 26 SYSTEM COLLECTIONS RULES
    // ==========================================

    // 1. Users
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // 2. Profiles (PII Split isolation)
    match /profiles/{profileId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == profileId;
      allow update: if isOwner(profileId) || isAdmin();
      allow delete: if isOwner(profileId) || isAdmin();
    }

    // 3. Showrooms
    match /showrooms/{showroomId} {
      allow read: if true;
      allow create: if isShowroomOwner() || isAdmin();
      allow update: if isShowroomOwner() || isAdmin();
      allow delete: if isAdmin();
    }

    // 4. Showroom Staff
    match /showroomStaff/{staffId} {
      allow read: if true;
      allow write: if isShowroomOwner() || isAdmin();
    }

    // 5. Vehicles
    match /vehicles/{vehicleId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin() || (isSignedIn() && incoming().createdBy == request.auth.uid);
    }

    // 6. Vehicle Images
    match /vehicleImages/{imageId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 7. Vehicle Videos
    match /vehicleVideos/{videoId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 8. Favorites
    match /favorites/{favId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 9. Messages
    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 10. Chats
    match /chats/{chatId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 11. Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isAdmin();
    }

    // 12. Search History
    match /searchHistory/{searchId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 13. Recent Views
    match /recentViews/{viewId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 14. Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 15. Ratings
    match /ratings/{ratingId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 16. Leads
    match /leads/{leadId} {
      allow read: if true;
      allow write: if true; // Organic capture can occur from Visitors
    }

    // 17. Visitors
    match /visitors/{visitorId} {
      allow read, write: if true; // Clickstream analytics captures general visitors
    }

    // 18. Support Tickets
    match /supportTickets/{ticketId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // 19. Payments
    match /payments/{paymentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isAdmin();
    }

    // 20. Subscriptions
    match /subscriptions/{subscriptionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isShowroomOwner();
    }

    // 21. Advertisements
    match /advertisements/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 22. Analytics
    match /analytics/{analyticsId} {
      allow read: if isAdmin() || isShowroomOwner();
      allow write: if true; // Client telemetry reporting
    }

    // 23. Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 24. Audit Logs
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if true; // App components can record security trails
    }

    // 25. SEO
    match /seo/{seoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 26. System Logs
    match /systemLogs/{logId} {
      allow read: if isAdmin();
      allow write: if true; // Logging from runtime clients
    }

    // Backward compatibility matchers
    match /listings/{listingId} {
      allow read, write: if true;
      match /comments/{commentId} { allow read, write: if true; }
      match /likes/{userId} { allow read, write: if true; }
      match /offers/{offerId} { allow read, write: if true; }
    }
    match /dealers/{dealerId} {
      allow read, write: if true;
      match /reviews/{reviewId} { allow read, write: if true; }
    }
    match /suggestions/{suggestionId} {
      allow read, write: if true;
    }
    match /bargains/{bargainId} {
      allow read, write: if true;
    }
    match /system/{docId} {
      allow read, write: if true;
    }
    match /lead_actions/{actionId} {
      allow read, write: if true;
    }
  }
}
